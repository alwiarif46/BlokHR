# ═══════════════════════════════════════════════════════════════
# SHAAVIR SERVER — ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Server ──
PORT=3000
NODE_ENV=production                     # production | development
LOG_LEVEL=info                          # fatal | error | warn | info | debug | trace

# ── Database ──
# Option A: SQLite (default — zero setup, file-based)
DB_ENGINE=sqlite
DB_PATH=./shaavir.db

# Option B: PostgreSQL (production-grade)
# DB_ENGINE=postgres
# DB_URL=postgresql://user:password@localhost:5432/shaavir

# ── Authentication ──
# Default admin credentials (created during setup wizard):
#   Username: (the admin email you enter in Step 3)
#   Password: admin  (must change on first login)
#
# Multiple auth providers can be enabled simultaneously.
# Configure via the Setup Wizard (Step 2) or directly in the branding table.
#
# Supported providers:
#   1. Email/Password (local)     — enabled by default
#   2. Magic Link (passwordless)  — toggle in branding.auth_magic_link_enabled
#   3. Microsoft Entra ID (MSAL)  — set msal_client_id + msal_tenant_id
#   4. Google OAuth               — set google_oauth_client_id
#   5. Generic OIDC               — Auth0, Okta, Keycloak, Oracle IDCS, OneLogin, PingIdentity
#   6. SAML 2.0                   — Enterprise SSO (any SAML IdP)
#   7. LDAP / Active Directory    — On-prem corporate directory

# ── File Storage ──
# Choose ONE storage provider:

# Option A: Local filesystem (default — no cloud dependency)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# Option B: AWS S3
# STORAGE_PROVIDER=aws_s3
# AWS_REGION=us-east-1
# AWS_BUCKET=shaavir-files
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Option C: S3-Compatible (Cloudflare R2, Oracle Object Storage, MinIO, DigitalOcean Spaces, Backblaze B2)
# STORAGE_PROVIDER=aws_s3
# AWS_REGION=auto
# AWS_BUCKET=shaavir-files
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com    # Cloudflare R2
# S3_ENDPOINT=https://namespace.compat.objectstorage.region.oraclecloud.com  # Oracle
# S3_ENDPOINT=http://localhost:9000                             # MinIO
# S3_ENDPOINT=https://region.digitaloceanspaces.com             # DO Spaces
# S3_ENDPOINT=https://s3.region.backblazeb2.com                 # Backblaze B2
# S3_PATH_STYLE=false                                           # Set true for MinIO

# Option D: Azure Blob Storage
# STORAGE_PROVIDER=azure_blob
# AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_BLOB_CONTAINER=shaavir-files

# ── Event Bus (optional) ──
# Default: in-memory (single instance, no durability)
# For multi-instance or durability, use Redis/Valkey:
# REDIS_URL=redis://localhost:6379
# EVENT_RETENTION_DAYS=90

# ── Face Recognition (optional) ──
# Azure Face API — only needed if face clock-in is enabled
# AZURE_FACE_ENDPOINT=https://your-region.api.cognitive.microsoft.com
# AZURE_FACE_KEY=your-face-api-key

# ── LLM / AI Chatbot (optional) ──
# LLM_PROVIDER=anthropic                # anthropic | ollama
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Email / SMTP (optional — for notifications, magic links) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=app-specific-password
# SMTP_FROM=noreply@yourdomain.com

# ── Notification Channels (all optional) ──
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/...
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0/...
# WHATSAPP_API_TOKEN=...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# CLICKUP_API_TOKEN=pk_...

# ── Security ──
# ACTION_LINK_SECRET=your-32-character-random-secret
# Used for signing action links in email notifications.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
